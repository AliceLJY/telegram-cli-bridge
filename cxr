#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${ENV_FILE:-$SCRIPT_DIR/.env.codex}"
LIMIT="${CXR_LIMIT:-12}"

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

API_URL="${TASK_API_URL:-http://127.0.0.1:3456}"
API_TOKEN="${TASK_API_TOKEN:-${WORKER_TOKEN:-}}"

if [[ -z "${API_TOKEN:-}" ]]; then
  echo "missing token: set TASK_API_TOKEN (or WORKER_TOKEN) in $ENV_FILE"
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required"
  exit 1
fi
if ! command -v codex >/dev/null 2>&1; then
  echo "codex CLI is required"
  exit 1
fi

json="$(curl -fsS \
  -H "Authorization: Bearer ${API_TOKEN}" \
  "${API_URL}/codex/recent?limit=${LIMIT}")"

count="$(jq -r '.sessions | length' <<<"$json")"
if [[ "${count}" -eq 0 ]]; then
  echo "no codex sessions from backend"
  exit 1
fi

mapfile -t rows < <(jq -r '.sessions[] | [.sessionId, .lastModified, (.topic // "(no topic)")] | @tsv' <<<"$json")

print_list() {
  local i=1
  echo "Codex recent sessions (backend):"
  for row in "${rows[@]}"; do
    local sid ts topic short
    sid="$(cut -f1 <<<"$row")"
    ts="$(cut -f2 <<<"$row")"
    topic="$(cut -f3 <<<"$row")"
    short="${sid:0:8}"
    printf "%2d) %s  %s  %s\n" "$i" "$short" "$ts" "$topic"
    i=$((i + 1))
  done
}

resolve_session_id() {
  local selector="$1"

  if [[ "$selector" =~ ^[0-9]+$ ]]; then
    local idx=$((selector - 1))
    if (( idx < 0 || idx >= count )); then
      echo "invalid index: $selector" >&2
      exit 1
    fi
    cut -f1 <<<"${rows[$idx]}"
    return
  fi

  mapfile -t matches < <(jq -r --arg s "$selector" '.sessions[] | select(.sessionId | startswith($s)) | .sessionId' <<<"$json")
  if [[ "${#matches[@]}" -eq 1 ]]; then
    echo "${matches[0]}"
    return
  fi
  if [[ "${#matches[@]}" -gt 1 ]]; then
    echo "ambiguous session prefix: $selector" >&2
    printf 'matches:\n' >&2
    printf '  %s\n' "${matches[@]}" >&2
    exit 1
  fi
  echo "session not found: $selector" >&2
  exit 1
}

if [[ "${1:-}" == "list" || "${1:-}" == "-l" || "${1:-}" == "--list" ]]; then
  print_list
  exit 0
fi

selector="${1:-}"
if [[ -z "$selector" ]]; then
  print_list
  printf "\nselect index (or session prefix): "
  read -r selector
fi

session_id="$(resolve_session_id "$selector")"
echo "resuming: $session_id"
exec codex resume "$session_id"

